+        result = stats1.aggregate(stats2)
+
+        assert result is stats1  # Should return self
+        offload_connector_stats = result
+        assert offload_connector_stats.data["CPU_to_GPU"] == [
+            {
+                "op_size": 16,
+                "op_time": 1.0
+            },
+            {
+                "op_size": 8,
+                "op_time": 0.5
+            },
+            {
+                "op_size": 3,
+                "op_time": 0.2
+            },
+            {
+                "op_size": 7,
+                "op_time": 0.9
+            },
+        ]
+        assert offload_connector_stats.data["GPU_to_CPU"] == [
+            {
+                "op_size": 1,
+                "op_time": 0.1
+            },
+            {
+                "op_size": 2,
+                "op_time": 0.2
+            },
+            {
+                "op_size": 16,
+                "op_time": 2
